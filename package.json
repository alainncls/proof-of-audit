{
  "name": "proof-of-audit",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc && vite build",
    "dev": "vite",
    "format": "prettier --check '**/*.css' '**/*.ts' '**/*.tsx' '**/*.json' '**/*.md'",
    "format:fix": "prettier --write '**/*.css' '**/*.ts' '**/*.tsx' '**/*.json' '**/*.md'",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "preview": "vite preview",
    "security:verify": "node --experimental-strip-types scripts/verify-security-fixes.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@reown/appkit": "1.8.21",
    "@reown/appkit-adapter-wagmi": "1.8.21",
    "@tanstack/react-query": "5.101.1",
    "@verax-attestation-registry/verax-sdk": "5.4.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "viem": "2.53.1",
    "wagmi": "3.6.15"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "24.13.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "eslint": "10.5.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "globals": "17.7.0",
    "prettier": "3.8.4",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.0",
    "vite": "8.1.0"
  },
  "overrides": {
    "@wagmi/connectors": "8.0.14"
  },
  "engines": {
    "node": "24.18.0"
  }
}
